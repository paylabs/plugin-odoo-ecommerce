<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form_paylabs_inherit" model="ir.ui.view">
        <field name="name">sale.order.form.paylabs.inherit</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <!-- 
                 We removed the custom buttons to follow the standard Odoo flow.
                 Transactions should be managed through the standard Odoo 
                 payment and transaction interfaces.
            -->
            <xpath expr="//sheet" position="inside">
                <field name="paylabs_has_pending_tx" invisible="1"/>
            </xpath>
        </field>
    </record>
</odoo>
