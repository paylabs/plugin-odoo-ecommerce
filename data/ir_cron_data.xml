<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Cron to cancel expired transactions every hour -->
        <record id="ir_cron_paylabs_cancel_expired" model="ir.cron">
            <field name="name">Paylabs: Cancel Expired Transactions</field>
            <field name="model_id" ref="payment.model_payment_transaction"/>
            <field name="state">code</field>
            <field name="code">model.cron_paylabs_cancel_expired()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
